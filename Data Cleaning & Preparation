USE New_Year

--THIS IS TO CONFIRM THAT ALL TABLES WERE IMPORTED 
SELECT TOP 10 * FROM plant1_gen;
SELECT TOP 10 * FROM plant1_weather;
SELECT TOP 10 * FROM plant2_gen;
SELECT TOP 10 * FROM plant2_weather;

-- THIS IS TO CHECK THE STRUCTURE OF THE TABLE
EXEC sp_help plant1_gen;
EXEC sp_help plant1_weather;

--TO MERGE GENERATION AND WEATHER DATA - PLANT 1
SELECT 
    g.DATE_TIME,
    g.PLANT_ID,
    g.SOURCE_KEY,
    g.DC_POWER,
    g.AC_POWER,
    g.DAILY_YIELD,
    g.TOTAL_YIELD,
    w.AMBIENT_TEMPERATURE,
    w.MODULE_TEMPERATURE,
    w.IRRADIATION
INTO plant1_data
FROM plant1_gen g
INNER JOIN plant1_weather w
ON g.DATE_TIME = w.DATE_TIME
AND g.PLANT_ID = w.PLANT_ID;

--I NOTICED TEHE DATE FORMAT IS WRONG, SO I NEED TO CHANGE THAT.
IF OBJECT_ID('plant1_gen_combined', 'U') IS NOT NULL
DROP TABLE plant1_gen_combined;

SELECT
    TRY_CONVERT(datetime, g.DATE_TIME, 105) AS DATE_TIME,
    g.PLANT_ID,
    g.SOURCE_KEY,
    g.DC_POWER,
    g.AC_POWER,
    g.DAILY_YIELD,
    g.TOTAL_YIELD,
    w.AMBIENT_TEMPERATURE,
    w.MODULE_TEMPERATURE,
    w.IRRADIATION
INTO plant1_gen_combined
FROM plant1_gen g
JOIN plant1_weather w
ON TRY_CONVERT(datetime, g.DATE_TIME, 105) =
   TRY_CONVERT(datetime, w.DATE_TIME, 105)
AND g.PLANT_ID = w.PLANT_ID;

SELECT 
    g.DATE_TIME,
    g.PLANT_ID,
    g.SOURCE_KEY,
    g.DC_POWER,
    g.AC_POWER,
    g.DAILY_YIELD,
    g.TOTAL_YIELD,
    w.AMBIENT_TEMPERATURE,
    w.MODULE_TEMPERATURE,
    w.IRRADIATION
INTO plant2_data
FROM plant2_gen g
INNER JOIN plant2_weather w
ON g.DATE_TIME = w.DATE_TIME
AND g.PLANT_ID = w.PLANT_ID;

-- COMBINE BOTH PLANTS  
SELECT *
INTO combined_data
FROM plant1_data

UNION ALL

SELECT *
FROM plant2_data;

SELECT TOP 10 * FROM combined_data;

-- ANALYTICAL QUERIES 
-- TOTAL POWER GENERATED BY EACH PLANT 
SELECT 
    PLANT_ID,
    SUM(AC_POWER) AS Total_Energy_Generated
FROM combined_data
GROUP BY PLANT_ID;

-- DAILY ENERGY GENERATION
SELECT 
    PLANT_ID,
    CAST(DATE_TIME AS DATE) AS Day,
    SUM(AC_POWER) AS Daily_Generation
FROM combined_data
GROUP BY PLANT_ID, CAST(DATE_TIME AS DATE)
ORDER BY Day;

-- PEAK GENERATION HOUR
SELECT 
    DATEPART(HOUR, DATE_TIME) AS Hour_of_Day,
    AVG(AC_POWER) AS Avg_Power
FROM combined_data
GROUP BY DATEPART(HOUR, DATE_TIME)
ORDER BY Avg_Power DESC;

-- HIGHEST GENERATION DAY
SELECT TOP 1
    CAST(DATE_TIME AS DATE) AS Day,
    SUM(AC_POWER) AS Daily_Generation
FROM combined_data
GROUP BY CAST(DATE_TIME AS DATE)
ORDER BY Daily_Generation DESC;

-- WEATHER IMPACT: IRRADIATION VS POWER
SELECT 
    AVG(IRRADIATION) AS Avg_Irradiation,
    AVG(AC_POWER) AS Avg_AC_Power
FROM combined_data;

-- TEMPERATURE VS POWER 
SELECT 
    ROUND(AMBIENT_TEMPERATURE,0) AS Temperature,
    AVG(AC_POWER) AS Avg_Power
FROM combined_data
GROUP BY ROUND(AMBIENT_TEMPERATURE,0)
ORDER BY Temperature;

-- TOP PERFORMING INVERTERS 
SELECT 
    SOURCE_KEY,
    SUM(AC_POWER) AS Total_Power
FROM combined_data
GROUP BY SOURCE_KEY
ORDER BY Total_Power DESC;

-- LOWEST PERFORMING INVERTERS 
SELECT TOP 10
    SOURCE_KEY,
    SUM(AC_POWER) AS Total_Power
FROM combined_data
GROUP BY SOURCE_KEY
ORDER BY Total_Power ASC;

-- EFFICIENCY METRIC (POWER PER RADIATION)
SELECT 
    PLANT_ID,
    AVG(AC_POWER / NULLIF(IRRADIATION,0)) AS Avg_Efficiency
FROM combined_data
GROUP BY PLANT_ID;

-- TO ENSURE QUALITY CHECKS 
SELECT COUNT(*) AS TOTAL_ROWS  
FROM combined_data;

SELECT COUNT(*) 
FROM combined_data
WHERE AC_POWER IS NULL;

SELECT 
    *,
    CAST(DATE_TIME AS DATE) AS Generation_Date,
    CAST(DATE_TIME AS TIME) AS Generation_Time,
    DATEPART(HOUR, DATE_TIME) AS Generation_Hour
INTO combined_data_clean
FROM combined_data;

SELECT* 
FROM combined_data; 

